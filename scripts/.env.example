# Copy to scripts/.env on the server and set values. Do not commit .env.
# Host port: map from ~/wazuh-docker-official/single-node/docker-compose.yml (container 55000 -> host).
#
# Credentials: match API_USERNAME / API_PASSWORD from that compose file, or use WAZUH_API_USER / WAZUH_API_PASSWORD.

WAZUH_API_URL=https://127.0.0.1:55000
API_USERNAME=wazuh-wui
API_PASSWORD=replace-with-your-api-password
